# Copy this file to ".env" (same folder) and edit. It is loaded AUTOMATICALLY on
# `npm start` — no extra step, works on Windows/macOS/Linux. Real shell env vars,
# if set, take precedence over this file.

# ── Alarm ────────────────────────────────────────────────────────────────────
# Alarm only when market liquidity AND your position are at least this (USDC).
MIN_TRIGGER_USDC=50
# Only alarm if the forceDeallocate+withdraw actually simulates (no false alarms).
CONFIRM_BY_SIM=1
# Minimum seconds between sounds while a window stays open (banner still prints).
ALARM_COOLDOWN_SEC=8
# Custom alarm command (any shell). Empty = built-in macOS sound.
# e.g. on Linux:  ALARM_CMD=paplay /usr/share/sounds/freedesktop/stereo/alarm-clock-elapsed.oga
ALARM_CMD=
# Speak the alert aloud with macOS `say` (1 on macOS by default).
SAY=1

# ── RPC ──────────────────────────────────────────────────────────────────────
# A private/paid endpoint is more reliable for long-running monitoring.
RPC_HTTP=https://ethereum-rpc.publicnode.com
# Optional wss:// endpoint for true newHeads subscription (lower latency).
RPC_WS=
# HTTP block-poll interval in seconds (~12s blocks). Ignored when RPC_WS is set.
POLL_SECONDS=4

# Shave this off the displayed "withdraw up to" amount (covers the
# forceDeallocate penalty + rounding so the figure is safe to act on). USDC.
SAFETY_BUFFER_USDC=1

# ── AUTO-WITHDRAW (optional — to actually beat the draining bot) ──────────────
# Move the vault shares to a fresh hot wallet first (see README), then:
EXECUTE=0
# Hot wallet that NOW HOLDS the moved vault shares (signs the withdrawal).
PRIVATE_KEY=
# Where withdrawn USDC lands — set to a COLD address you control.
RECEIVER=
# (optional) override the share-holding owner; defaults to PRIVATE_KEY's address.
OWNER=
# Priority fee (gwei) to win inclusion vs the competing bot. Raise if you lose.
PRIORITY_GWEI=20
# Optional max fee per gas cap (gwei). Empty = auto.
MAX_FEE_GWEI=
# Fixed gas limit (skips estimateGas latency). Multicall ~250-350k.
GAS_LIMIT=600000

# ── Misc ─────────────────────────────────────────────────────────────────────
LOGFILE=morpho-monitor.log
