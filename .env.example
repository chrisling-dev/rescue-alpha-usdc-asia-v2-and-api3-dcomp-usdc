# Copy to .env and fill in. NEVER commit your real .env (it's gitignored).
# Load it however you like, e.g.:  set -a && source .env && set +a && npm start

# ── Execution mode ───────────────────────────────────────────────────────────
# 1 = dry-run (simulate + log only, broadcasts nothing). 0 = actually broadcast.
DRY_RUN=1

# ── Signers (LIVE mode only) ────────────────────────────────────────────────
# One private key per vault — each MUST be that vault's verified owner, or the
# script refuses it. Omit a key to simply skip that vault.
#   AZND vault owner: 0x6b06da993b1f12d82463fec75006913f98499b7c
#   dCOMP vault owner: 0xd87617659957f4d9cea85e9db85b2f1de677646a
PRIVATE_KEY_ALPHA=
PRIVATE_KEY_API3=

# Where withdrawn USDC should land (defaults to each vault's owner).
RECEIVER_ALPHA=
RECEIVER_API3=

# ── RPC ──────────────────────────────────────────────────────────────────────
# A private/paid endpoint is strongly recommended for live racing.
RPC_HTTP=https://ethereum-rpc.publicnode.com
# Optional wss:// endpoint for true newHeads subscription (lower latency).
RPC_WS=

# ── Tuning ───────────────────────────────────────────────────────────────────
# Only act when market liquidity AND owner position are at least this (USDC).
MIN_TRIGGER_USDC=50
# Shave this off the grab; covers the forceDeallocate penalty + rounding (USDC).
SAFETY_BUFFER_USDC=1
# HTTP block-poll interval in seconds (~12s blocks). Ignored when RPC_WS is set.
POLL_SECONDS=4
# Priority fee (gwei) tipped to the proposer to win inclusion.
PRIORITY_GWEI=5
# Optional hard cap on max fee per gas (gwei). Empty = let viem estimate.
MAX_FEE_GWEI=
# Log file path.
LOGFILE=morpho-monitor.log
# 1 = stop once a position is fully drained.
EXIT_AFTER_FULL=0
